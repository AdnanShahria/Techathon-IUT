{
  "name": "smart-office-monitor",
  "version": "1.0.0",
  "description": "Real-time office device monitoring system with web dashboard and Discord bot",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:full": "node scripts/dev-full.mjs",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend && npx vite --host",
    "build": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install"
  },
  "dependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^9.4.1"
  }
}
